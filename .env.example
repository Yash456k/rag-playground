# Copy to .env only on the VPS. Never commit the real file.
GROQ_API_KEY=replace-on-server
POSTGRES_DB=rag_playground
POSTGRES_USER=rag_playground
POSTGRES_PASSWORD=generate-a-long-random-password
DATABASE_URL=postgresql://rag_playground:replace-with-url-encoded-password@db:5432/rag_playground
FRONTEND_ORIGINS=https://replace-with-vercel-production-domain
PUBLIC_API_URL=https://rag-api.example.com
API_DOMAIN=rag-api.example.com
PUBLIC_IPV4=178.104.56.243
ACME_EMAIL=replace-with-acme-contact-email
ALLOWED_HOSTS=rag-api.example.com,localhost,127.0.0.1
TRUSTED_PROXY_CIDRS=127.0.0.1/32,172.16.0.0/12
IP_HASH_SALT=generate-a-long-random-value
VERIFY_FALLBACK_TOKEN=generate-a-long-random-value
PER_IP_DAILY_LIMIT=30
GLOBAL_DAILY_LIMIT=500
LOG_LEVEL=INFO
